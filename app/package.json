{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "author": "时光微醉-mazh <18992880651>",
  "type": "module",
  "scripts": {
    "dev": "vite --mode native",
    "dev:web-preview": "vite --mode web-preview",
    "dev:mobile": "vite --mode native --host 0.0.0.0 --port 5173 --strictPort",
    "build": "vue-tsc -b && vite build --mode native",
    "build:web-preview": "vue-tsc -b && vite build --mode web-preview",
    "preview": "vite preview",
    "cap:sync": "npx cap sync",
    "cap:sync:android": "npx cap sync android",
    "cap:add:android": "npx cap add android",
    "cap:open:android": "npx cap open android",
    "mobile:prepare:android": "npm run build && npm run cap:sync:android",
    "mobile:run:android": "npm run mobile:prepare:android && npx cap run android",
    "mobile:live:url": "node ./scripts/show-mobile-url.mjs",
    "mobile:live:android": "powershell -ExecutionPolicy Bypass -File ./scripts/run-android-live.ps1",
    "android:assemble:debug": "cmd /c \"cd android && gradlew.bat assembleDebug\"",
    "android:lint": "cmd /c \"cd android && gradlew.bat lintDebug\"",
    "android:test:unit": "cmd /c \"cd android && gradlew.bat testDebugUnitTest\"",
    "android:test:instrumented": "cmd /c \"cd android && gradlew.bat connectedDebugAndroidTest\"",
    "android:verify": "npm run mobile:prepare:android && npm run android:assemble:debug && npm run android:lint && npm run android:test:unit"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^8.0.1",
    "@capacitor/android": "^8.2.0",
    "@capacitor/camera": "^8.0.2",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/filesystem": "^8.1.2",
    "dayjs": "^1.11.19",
    "echarts": "^6.0.0",
    "lucide-vue-next": "^0.577.0",
    "pinia": "^3.0.4",
    "sql.js": "1.14.1",
    "vue": "^3.5.25",
    "vue-router": "^4.6.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vue-tsc": "^3.1.5"
  }
}
