# 根目录的 .gitignore 已覆盖大部分规则
# 此文件作为独立 app/ 子项目时的备用

# 依赖
node_modules/

# 构建产物
dist/
dist-ssr/

# Capacitor 原生平台（由 CI 生成）
android/
ios/

# 本地环境变量
*.local
.env
.env.local
.env.*.local

# 仅用于浏览器调试的 WASM
public/assets/sql-wasm.wasm

# 日志
*.log
npm-debug.log*
yarn-debug.log*

# 编辑器
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
